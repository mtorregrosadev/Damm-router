# ──────────────────────────────────────────────────────────────────────────────
# Python backend (src/db/mongo.py, src/alghoritms/router.py, src/main.py)
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGO_URI=

# MongoDB database name
MONGO_DB=damm-base

# ──────────────────────────────────────────────────────────────────────────────
# Next.js frontend (web/.env.local)
# Copy these keys to web/.env.local with real values for local development.
# In Vercel, configure them in the project's Environment Variables dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (same cluster as MONGO_URI above)
MONGODB_URI=

# MongoDB database name
MONGODB_DB=damm-base

# Collection names (change only if you rename them in MongoDB)
MONGODB_COLLECTION_RUTA_PUNTS=ruta_punts
MONGODB_COLLECTION_RUTA_RESUM=ruta_resum
MONGODB_COLLECTION_RESULTADOS=resultados
MONGODB_COLLECTION_DETALLE=detalle_entrega
MONGODB_COLLECTION_HORARIOS=horarios_entrega
